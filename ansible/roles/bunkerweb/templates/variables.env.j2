# /etc/bunkerweb/variables.env
# Configuration principale BunkerWeb {{ bunkerweb_version }}
# Générée par Packer/Ansible – modifiez via user-data ou bunkerweb-first-boot.sh
#
# Documentation : https://docs.bunkerweb.io/latest/settings/

# ── Réseau ──────────────────────────────────────────────────────────────────
# Adresse d'écoute de l'API interne (127.0.0.1 en standalone Full Stack)
API_LISTEN_ADDR=127.0.0.1
API_HTTP_PORT=5000

# IPs autorisées à contacter l'API interne
API_WHITELIST_IP=127.0.0.0/8

# ── Services web à protéger ──────────────────────────────────────────────────
# Décommentez et adaptez pour chaque site
# SERVER_NAME=www.exemple.fr
# HTTP_PORT=8080
# HTTPS_PORT=8443
# USE_REVERSE_PROXY=yes
# REVERSE_PROXY_URL=/
# REVERSE_PROXY_HOST=http://127.0.0.1:8000
# AUTO_LETS_ENCRYPT=yes
# EMAIL_LETS_ENCRYPT=admin@exemple.fr

# ── Sécurité globale ─────────────────────────────────────────────────────────
USE_MODSECURITY=yes
USE_MODSECURITY_CRS=yes
USE_MODSECURITY_GLOBAL_CRS=yes
USE_BAD_BEHAVIOR=yes
USE_DNSBL=yes
USE_ANTIBOT=no
USE_GZIP=yes

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=warning
ACCESS_LOG=/var/log/bunkerweb/access.log
ERROR_LOG=/var/log/bunkerweb/error.log
