# /etc/bunkerweb/ui.env
# Configuration de la Web UI BunkerWeb {{ bunkerweb_version }}
# Les credentials admin sont définis au premier démarrage via bunkerweb-first-boot.sh

# Écoute UI (localhost uniquement – exposé via BunkerWeb en reverse proxy)
UI_LISTEN_ADDR=127.0.0.1
UI_LISTEN_PORT=7000

# Ces valeurs seront surchargées par le script first-boot si définies en user-data
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=ChangeMe!

# Forwarded IPs autorisées (localhost = BunkerWeb en front)
UI_FORWARDED_ALLOW_IPS=127.0.0.1
