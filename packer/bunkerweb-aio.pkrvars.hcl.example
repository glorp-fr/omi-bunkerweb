# Fichier de variables Packer – NE PAS commiter en VCS
# Copiez ce fichier en bunkerweb-aio.pkrvars.hcl et remplissez les valeurs

access_key        = "VOTRE_ACCESS_KEY"
secret_key        = "VOTRE_SECRET_KEY"
region            = "eu-west-2"
vm_type           = "tinav5.c2r4p3"
bunkerweb_version = "1.6.11"

# ID de l'OMI Debian 13 source – obligatoire
# Pour trouver la dernière disponible dans votre région :
#   osc-cli api ReadImages --profile default \
#     --Filters '{"AccountAliases":["Outscale"],"ImageNames":["Debian-13-*"],"Architectures":["x86_64"]}' \
#     | grep -E '"ImageId"|"ImageName"'
source_omi_id = "ami-XXXXXXXX"
